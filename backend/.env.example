# MySQL (same database as auth; ML predictions stored in table `predictions`)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=agrosense_auth
# Optional alias:
# MYSQL_DATABASE=agrosense_auth

# Cloudinary — browser upload reads these if VITE_* are unset (see GET /config/cloudinary).
# https://cloudinary.com/console — Cloud name must not be MYSQL_USER (e.g. not "root").
CLOUDINARY_CLOUD_NAME=
# Unsigned upload preset name (Settings → Upload → Upload presets). Required for browser upload.
CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Hugging Face — https://huggingface.co/settings/tokens
# Fine-grained token: enable "Make calls to Inference Providers", or router returns HTTP 403.
# Supported names (first non-empty wins): HF_API_KEY, HUGGINGFACEHUB_API_TOKEN, HF_TOKEN
HF_API_KEY=
# Plant disease model (change if needed)
HF_MODEL_ID=linkanjarad/mobilenet_v2_rai_CropDisease
# Optional: default is the Hub router (legacy api-inference.huggingface.co returns HTTP 410).
# HF_INFERENCE_MODELS_BASE=https://router.huggingface.co/hf-inference/models

# Google Gemini — https://aistudio.google.com/apikey
# Used for insights; also used as vision fallback when Hugging Face classification fails.
GEMINI_API_KEY=
# Required for predictable behavior: set a Gemini 2.5 id (default in code is gemini-2.5-flash if unset).
# Examples: gemini-2.5-flash, gemini-2.5-pro (must match names from GET /health/gemini → models_preview).
GEMINI_MODEL=gemini-2.5-flash
# Optional: comma-separated backup ids only (no legacy 1.5 values are auto-appended).
# GEMINI_MODEL_FALLBACKS=gemini-2.5-pro
# Optional REST endpoint if required by your network / proxy.
# GEMINI_API_ENDPOINT=https://generativelanguage.googleapis.com
