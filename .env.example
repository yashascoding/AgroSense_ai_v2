# Copy to `.env` or `.env.local` in THIS folder (Agrosense_ai/) and restart `npm run dev`.
# If these are empty, the app will try `GET /config/cloudinary` and use backend/.env instead.

VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# Optional API base (defaults to same hostname as this app, port 5000)
# VITE_API_BASE=http://127.0.0.1:5000
